{
  "name": "@negotium/adapter-otium",
  "version": "0.1.12",
  "private": true,
  "type": "module",
  "description": "Join an Otium workspace and run placed rooms on a Negotium node",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./relay": {
      "types": "./dist/relay.d.ts",
      "default": "./dist/relay.js"
    }
  },
  "bin": {
    "negotium-otium": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/negotium.git",
    "directory": "adapters/otium"
  },
  "homepage": "https://github.com/maestrojeong/negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/negotium/issues"
  },
  "scripts": {
    "serve": "bun src/cli.ts serve",
    "build": "bun ../../scripts/build-package.ts src/index.ts src/cli.ts src/relay.ts",
    "check": "bunx tsc --noEmit",
    "lint": "biome check",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@negotium/adapter-sdk": "workspace:*",
    "@negotium/core": "workspace:*",
    "@negotium/node": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  }
}
