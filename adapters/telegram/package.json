{
  "name": "@negotium/adapter-telegram",
  "version": "0.1.17",
  "private": true,
  "type": "module",
  "description": "Telegram channel adapter for Negotium, including forum-topic mode",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "bin": {
    "negotium-telegram": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/negotium.git",
    "directory": "adapters/telegram"
  },
  "homepage": "https://github.com/maestrojeong/negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/negotium/issues"
  },
  "scripts": {
    "build": "bun ../../scripts/build-package.ts src/index.ts src/cli.ts",
    "check": "bunx tsc --noEmit",
    "lint": "biome check",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@negotium/adapter-sdk": "workspace:*",
    "@negotium/core": "workspace:*",
    "@negotium/node": "workspace:*",
    "node-telegram-bot-api": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  }
}
