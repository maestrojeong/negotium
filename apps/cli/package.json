{
  "name": "@negotium/cli",
  "version": "0.1.6",
  "type": "module",
  "description": "negotium CLI — init a node, manage its MCPs, and chat with the multi-agent runtime from the terminal",
  "license": "Apache-2.0",
  "bin": {
    "negotium": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/negotium.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/maestrojeong/negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/negotium/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun ../../scripts/build-package.ts src/main.ts",
    "check": "bunx tsc --noEmit",
    "lint": "biome check",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@negotium/adapter-otium": "0.1.6",
    "@negotium/adapter-telegram": "0.1.6",
    "@negotium/adapter-terminal": "0.1.6",
    "@negotium/core": "0.1.6",
    "@negotium/mcp-host": "0.1.6",
    "@negotium/module-cron": "0.1.6",
    "@negotium/node": "0.1.6"
  },
  "devDependencies": {
    "@negotium/adapter-sdk": "0.1.6",
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  },
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    ".": "./dist/main.js"
  }
}
