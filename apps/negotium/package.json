{
  "name": "negotium",
  "version": "0.1.0",
  "type": "module",
  "description": "Install the Negotium multi-agent runtime and CLI with one package",
  "license": "Apache-2.0",
  "bin": {
    "negotium": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/Negotium.git",
    "directory": "apps/negotium"
  },
  "homepage": "https://github.com/maestrojeong/Negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/Negotium/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun ../../scripts/build-package.ts src/main.ts",
    "check": "bunx tsc --noEmit",
    "lint": "biome check",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@negotium/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  }
}
