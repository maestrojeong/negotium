{
  "name": "negotium",
  "version": "0.1.8",
  "type": "module",
  "description": "Install the Negotium multi-agent runtime and CLI with one package",
  "license": "Apache-2.0",
  "bin": {
    "negotium": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/negotium.git",
    "directory": "apps/negotium"
  },
  "homepage": "https://github.com/maestrojeong/negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/negotium/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun ../../scripts/build-negotium-package.ts",
    "check": "bunx tsc --noEmit",
    "lint": "biome check",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.144.4",
    "maestro-agent-sdk": "0.1.45",
    "mcp-patchright": "0.1.10",
    "node-telegram-bot-api": "^1.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  },
  "imports": {
    "#*": "./dist/runtime/src/*.ts"
  }
}
