{
  "name": "negotium",
  "version": "0.1.27",
  "type": "module",
  "description": "Install the Negotium multi-agent runtime and CLI with one package",
  "license": "Apache-2.0",
  "bin": {
    "negotium": "dist/main.js"
  },
  "exports": {
    "./hosted-agent": {
      "types": "./dist/types/packages/core/src/agents/hosted-agent.d.ts",
      "import": "./dist/hosted-agent.js",
      "default": "./dist/hosted-agent.js"
    },
    "./canonical-mcp-bridge": {
      "types": "./dist/types/packages/core/src/mcp/canonical-bridge-config.d.ts",
      "import": "./dist/canonical-mcp-bridge.js",
      "default": "./dist/canonical-mcp-bridge.js"
    },
    "./cron": {
      "types": "./dist/types/packages/module-cron/src/index.d.ts",
      "import": "./dist/cron.js",
      "default": "./dist/cron.js"
    },
    "./mcp-servers": {
      "types": "./dist/types/apps/negotium/src/mcp-servers.d.ts",
      "import": "./dist/mcp-servers.js",
      "default": "./dist/mcp-servers.js"
    },
    "./registry": {
      "types": "./dist/types/packages/core/src/agents/registry.d.ts",
      "import": "./dist/registry.js",
      "default": "./dist/registry.js"
    },
    "./rollout": {
      "types": "./dist/types/packages/core/src/agents/rollout/index.d.ts",
      "import": "./dist/rollout.js",
      "default": "./dist/rollout.js"
    },
    "./vault": {
      "types": "./dist/types/packages/core/src/storage/vault-public.d.ts",
      "import": "./dist/vault.js",
      "default": "./dist/vault.js"
    },
    "./storage": {
      "types": "./dist/types/packages/core/src/storage/storage-public.d.ts",
      "import": "./dist/storage.js",
      "default": "./dist/storage.js"
    },
    "./prompts": {
      "types": "./dist/types/packages/core/src/prompts/builders.d.ts",
      "import": "./dist/prompts.js",
      "default": "./dist/prompts.js"
    },
    "./runtime-helpers": {
      "types": "./dist/types/packages/core/src/runtime/public-helpers.d.ts",
      "import": "./dist/runtime-helpers.js",
      "default": "./dist/runtime-helpers.js"
    },
    "./mcp-factories": {
      "types": "./dist/types/packages/core/src/mcp/factories/index.d.ts",
      "import": "./dist/mcp-factories.js",
      "default": "./dist/mcp-factories.js"
    },
    "./agent-helpers": {
      "types": "./dist/types/packages/core/src/agents/public-helpers.d.ts",
      "import": "./dist/agent-helpers.js",
      "default": "./dist/agent-helpers.js"
    },
    "./mcp-catalog": {
      "types": "./dist/types/packages/core/src/platform/mcp-catalog-policy.d.ts",
      "import": "./dist/mcp-catalog.js",
      "default": "./dist/mcp-catalog.js"
    },
    "./background-bash": {
      "types": "./dist/types/packages/core/src/platform/background-bash/manager.d.ts",
      "import": "./dist/background-bash.js",
      "default": "./dist/background-bash.js"
    },
    "./outbox": {
      "types": "./dist/types/packages/core/src/outbox/index.d.ts",
      "import": "./dist/outbox.js",
      "default": "./dist/outbox.js"
    },
    "./query-runtime": {
      "types": "./dist/types/packages/core/src/query/public-runtime.d.ts",
      "import": "./dist/query-runtime.js",
      "default": "./dist/query-runtime.js"
    },
    "./platform-runtime": {
      "types": "./dist/types/packages/core/src/platform/public-runtime.d.ts",
      "import": "./dist/platform-runtime.js",
      "default": "./dist/platform-runtime.js"
    },
    "./sqlite": {
      "types": "./dist/types/packages/core/src/storage/sqlite.d.ts",
      "import": "./dist/sqlite.js",
      "default": "./dist/sqlite.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/negotium.git",
    "directory": "apps/negotium"
  },
  "homepage": "https://github.com/maestrojeong/negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/negotium/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun ../../scripts/build-negotium-package.ts",
    "check": "bunx tsc --noEmit",
    "lint": "biome check",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.144.4",
    "maestro-agent-sdk": "0.1.47",
    "mcp-patchright": "0.1.11",
    "node-telegram-bot-api": "^1.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  },
  "imports": {
    "#*": {
      "types": "./dist/types/packages/core/src/*.d.ts",
      "default": "./dist/runtime/src/*.ts"
    }
  }
}
