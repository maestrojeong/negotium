# Copy to .env (gitignored) and fill in. Bun auto-loads .env from the repo root.

# ── Telegram host (examples/telegram) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=""                # From @BotFather (reuse the clawgram bot's token — stop clawgram first)
TELEGRAM_ALLOWED_USERS=""            # Comma-separated Telegram user IDs

# ── Agents ────────────────────────────────────────────────────────────
# claude: authenticates via Claude CLI OAuth — leave ANTHROPIC_API_KEY unset.
# codex:  authenticates via its own CLI auth (~/.codex/auth.json).
DEEPSEEK_API_KEY=""                  # Required for the maestro agent (deepseek models)
GEMINI_API_KEY=""                    # Optional — maestro's Gemini image-QA tool

# ── Node ──────────────────────────────────────────────────────────────
# NEGOTIUM_PORT="7777"               # The node's open port (MCP endpoint)
# NEGOTIUM_STATE_DIR=""              # Default ~/.negotium
# FALLBACK_AGENT="claude"            # Default agent for new topics (claude|codex|maestro)
# LOG_LEVEL="info"                   # debug | info | warn | error | fatal

# ── Cron module ──────────────────────────────────────────────────────
# NEGOTIUM_CRON="1"                  # Set to 0 to keep the module unloaded
# NEGOTIUM_CRON_QUEUE_TIMEOUT_MS="300000"
# NEGOTIUM_CRON_SCRIPT_TIMEOUT_MS="600000"
# NEGOTIUM_CRON_JOBS_DIR=""          # Default ~/.negotium/workspace/cron/jobs
# NEGOTIUM_CRON_PYTHON=""            # Default uv when present, otherwise python3

# ── Media pipeline (optional, for future adapter features) ───────────
# FFMPEG_BIN="/opt/homebrew/bin/ffmpeg"
# TESSERACT_BIN=""                   # PATH lookup by default
# PDFTOTEXT_BIN=""                   # PATH lookup by default
