{
  "name": "@negotium/core",
  "version": "0.1.16",
  "private": true,
  "type": "module",
  "description": "Multi-agent AI runtime — Claude/Codex/Maestro providers, unified event stream, sessions, wiki/skills, local-first storage",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./hosted-agent": "./src/agents/hosted-agent.ts",
    "./registry": "./src/agents/registry.ts",
    "./rollout": "./src/agents/rollout/index.ts",
    "./vault": "./src/storage/vault-public.ts",
    "./storage": "./src/storage/storage-public.ts",
    "./prompts": "./src/prompts/builders.ts",
    "./runtime-helpers": "./src/runtime/public-helpers.ts",
    "./peer-session-bridge-ipc": "./src/mcp/session-comm/bridge-ipc-config.ts",
    "./canonical-mcp-bridge": "./src/mcp/canonical-bridge-config.ts",
    "./src/*": "./src/*"
  },
  "files": [
    "src",
    "scripts",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/negotium.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/maestrojeong/negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/negotium/issues"
  },
  "scripts": {
    "build": "bunx tsc --noEmit",
    "lint": "biome check",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.144.4",
    "maestro-agent-sdk": "0.1.45",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6",
    "tsx": "^4.22.4",
    "mcp-patchright": "0.1.10"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  },
  "imports": {
    "#*": "./src/*.ts"
  }
