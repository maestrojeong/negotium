{
  "name": "@negotium/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-agent AI runtime \u2014 Claude/Codex/Maestro providers, unified event stream, sessions, wiki/skills, local-first storage",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": "./src/*"
  },
  "files": [
    "src",
    "meta",
    "scripts",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/Negotium.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/maestrojeong/Negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/Negotium/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx tsc --noEmit",
    "lint": "biome check",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.144.1",
    "maestro-agent-sdk": "0.1.44",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6",
    "tsx": "^4.22.4",
    "mcp-patchright": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  },
  "imports": {
    "#*": "./src/*.ts"
  }
}
