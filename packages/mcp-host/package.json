{
  "name": "@negotium/mcp-host",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server process manager \u2014 port allocation, transports, health checks, idle eviction, per-node MCP manifest",
  "license": "Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": "./src/*"
  },
  "files": [
    "src",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/Negotium.git",
    "directory": "packages/mcp-host"
  },
  "homepage": "https://github.com/maestrojeong/Negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/Negotium/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx tsc --noEmit",
    "lint": "biome check",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  },
  "imports": {
    "#*": "./src/*.ts"
  }
}
