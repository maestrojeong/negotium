{
  "name": "@negotium/adapter-testkit",
  "version": "0.1.28",
  "private": true,
  "type": "module",
  "description": "Framework-neutral contract assertions for Negotium adapters",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maestrojeong/negotium.git",
    "directory": "packages/adapter-testkit"
  },
  "homepage": "https://github.com/maestrojeong/negotium#readme",
  "bugs": {
    "url": "https://github.com/maestrojeong/negotium/issues"
  },
  "scripts": {
    "build": "bun ../../scripts/build-package.ts src/index.ts",
    "check": "bunx tsc --noEmit",
    "lint": "biome check",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@negotium/adapter-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  }
}
